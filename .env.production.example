# ============================================================
# .env.production — 生产环境变量模板
#
# 复制此文件为 .env.production，填入真实值后使用：
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml --profile production up -d
#
# 必须修改的项：JWT_SECRET, JWT_REFRESH_SECRET, MYSQL_ROOT_PASSWORD,
#               CORS_ORIGINS, PROMO_BASE_URL, QINIU_SECRET_KEY
# ============================================================

# ---------- 基础 ----------
NODE_ENV=production
DOCKER_RESTART=always

# ---------- 数据库 ----------
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_DATABASE=course_distribute
MYSQL_PORT=3306

# ---------- Redis ----------
REDIS_PASSWORD=
REDIS_PORT=6379

# ---------- 后端服务 ----------
PORT=3000
BACKEND_PORT=3000

# ---------- JWT（必须使用强随机密钥，生产环境禁止使用默认值）----------
# 生成方法：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_node_e_console_log_crypto_randombytes64_toString_hex
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_node_e_console_log_crypto_randombytes64_toString_hex
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ---------- 跨域与安全 ----------
# 生产环境必须配置为你的已备案域名（微信小程序要求 HTTPS）
CORS_ORIGINS=https://你的域名.com
PROMO_BASE_URL=https://你的域名.com

# ---------- 微信登录 ----------
# 在微信公众平台 -> 开发管理 -> 开发设置 中获取
WECHAT_APPID=wx0000000000000000
WECHAT_SECRET=CHANGE_ME

# ---------- 七牛云 ----------
# 在七牛云控制台获取 AccessKey/SecretKey
QINIU_ACCESS_KEY=CHANGE_ME
QINIU_SECRET_KEY=CHANGE_ME
QINIU_BUCKET=CHANGE_ME
# 七牛 bucket 对应的公共域名（或你的 CDN 域名）
QINIU_PUBLIC_DOMAIN=https://你的七牛bucket域名.com
# 签名 URL 有效期（秒）
QINIU_URL_EXPIRE=3600

# ---------- Nginx ----------
NGINX_PORT=80
NGINX_SSL_PORT=443
