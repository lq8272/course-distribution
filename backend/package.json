{
  "name": "course-distribute-backend",
  "version": "1.0.0",
  "description": "视频课程分销系统后端API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "init-db": "node src/scripts/initDb.js",
"test": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit --runInBand",
    "test:auth": "cross-env NODE_ENV=test jest tests/auth.test.js --detectOpenHandles --forceExit --runInBand",
    "test:business": "cross-env NODE_ENV=test jest tests/business.test.js --detectOpenHandles --forceExit --runInBand",
    "test:edge": "cross-env NODE_ENV=test jest tests/edge-cases.test.js --detectOpenHandles --forceExit --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "nanoid": "^3.3.7",
    "qiniu": "^7.15.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "cross-env": "^10.1.0",
    "jest": "^30.3.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}
