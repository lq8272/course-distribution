# 前端 E2E 测试 nginx 服务
# Build context: 项目根目录 /
# 用法: docker build -f Dockerfile.e2e.frontend -t course-frontend:e2e .
FROM nginx:alpine
# 复制 H5 构建产物
COPY frontend/dist/build/h5/ /usr/share/nginx/html/
# 复制 nginx 配置（build context 内）
COPY frontend/dist/build/h5/e2e-nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
